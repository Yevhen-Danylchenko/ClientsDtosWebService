@model ClientsDtosWebService.Models.ClientsIndexViewModel

@{
    ViewData["Title"] = "Clients";
}

<h2>Clients List</h2>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Password</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model.Clients)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.Email</td>
                <td>@client.Password</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@client.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h3>Add New Client</h3>
<form asp-action="Index" method="post">
    <div class="mb-3">
        <label asp-for="NewClient.Name" class="form-label"></label>
        <input asp-for="NewClient.Name" class="form-control" />
        <span asp-validation-for="NewClient.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NewClient.Email" class="form-label"></label>
        <input asp-for="NewClient.Email" class="form-control" />
        <span asp-validation-for="NewClient.Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NewClient.Password" class="form-label"></label>
        <input asp-for="NewClient.Password" type="password" class="form-control" />
        <span asp-validation-for="NewClient.Password" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Add Client</button>
</form>



